{
  "entities": {
    "User": {
      "title": "User",
      "description": "User profile information",
      "type": "object",
      "properties": {
        "uid": { "type": "string", "description": "Unique user ID from Firebase Auth" },
        "email": { "type": "string", "format": "email", "description": "User email address" },
        "displayName": { "type": "string", "description": "User display name" },
        "photoURL": { "type": "string", "format": "uri", "description": "User profile photo URL" },
        "role": { "type": "string", "enum": ["admin", "user"], "description": "User role" },
        "createdAt": { "type": "string", "format": "date-time", "description": "Account creation timestamp" }
      },
      "required": ["uid", "email", "role", "createdAt"]
    },
    "CreditProfile": {
      "title": "CreditProfile",
      "description": "Credit analysis and loan decision profile",
      "type": "object",
      "properties": {
        "uid": { "type": "string", "description": "Owner's user ID" },
        "cibilScore": { "type": "number", "description": "User's CIBIL score" },
        "monthlyIncome": { "type": "number", "description": "Monthly income" },
        "totalDebts": { "type": "number", "description": "Total existing debts" },
        "loanAmount": { "type": "number", "description": "Requested loan amount" },
        "loanTenure": { "type": "number", "description": "Loan tenure in months" },
        "finalScore": { "type": "number", "description": "Calculated final score" },
        "decision": { "type": "string", "enum": ["Approved", "Rejected", "Manual Review"], "description": "Loan decision" },
        "analysis": { "type": "string", "description": "Detailed analysis text" },
        "createdAt": { "type": "string", "format": "date-time", "description": "Profile creation timestamp" }
      },
      "required": ["uid", "cibilScore", "monthlyIncome", "loanAmount", "decision", "createdAt"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "User",
      "description": "User profile documents"
    },
    "/credit_profiles/{profileId}": {
      "schema": "CreditProfile",
      "description": "Credit analysis results"
    }
  }
}
